# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# PortOne (결제)
NEXT_PUBLIC_PORTONE_STORE_ID=your_store_id
PORTONE_API_SECRET=your_api_secret
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=your_channel_key
PORTONE_WEBHOOK_SECRET=your_webhook_secret

# Naver OAuth (Supabase 대시보드의 Custom OIDC Provider로 설정)
# NAVER_CLIENT_ID와 NAVER_CLIENT_SECRET은 Next.js 환경변수가 아닌
# Supabase 대시보드 > Authentication > Providers에서 직접 입력해야 합니다.
# 네이버 개발자센터: https://developers.naver.com/apps/#/register

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
